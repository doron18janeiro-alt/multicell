generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id            String         @id @default(uuid())
  name          String
  phone         String
  document      String?
  companyId     String         @default("multicell-oficial") @map("company_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  birthDate     DateTime?      @map("birth_date") @db.Date
  pendingBalance Float         @default(0) @map("pending_balance")
  serviceOrders ServiceOrder[]
  foodOrders    FoodOrder[]
  foodOrderPayments FoodOrderPayment[]
  pendingEntries CustomerPendingEntry[]
  sales         Sale[]

  @@unique([document, companyId])
  @@index([companyId], map: "idx_customers_company_id")
  @@map("clients")
}

model Product {
  id                      String         @id @default(cuid())
  name                    String
  barcode                 String?        @map("barcode")
  stock                   Int            @default(0)
  minStock                Int            @default(5) @map("min_stock")
  category                String
  companyId               String         @map("company_id")
  createdAt               DateTime       @default(now()) @map("created_at")
  costPrice               Float          @default(0) @map("cost_price")
  description             String?
  minQuantity             Int            @default(2) @map("min_quantity")
  salePrice               Float          @map("sale_price")
  supplierId              String?        @map("supplier_id")
  updatedAt               DateTime       @updatedAt @map("updated_at")
  vehicleBrand            String?        @map("vehicle_brand")
  vehicleModel            String?        @map("vehicle_model")
  vehiclePlate            String?        @map("vehicle_plate")
  vehicleChassis          String?        @map("vehicle_chassis")
  vehicleRenavam          String?        @map("vehicle_renavam")
  vehicleStatus           VehicleStatus? @default(DISPONIVEL) @map("vehicle_status")
  vehicleManufactureYear  Int?           @map("vehicle_manufacture_year")
  vehicleModelYear        Int?           @map("vehicle_model_year")
  vehicleEngine           String?        @map("vehicle_engine")
  vehicleColor            String?        @map("vehicle_color")
  vehicleMileage          Int?           @map("vehicle_mileage")
  vehicleFuel             String?        @map("vehicle_fuel")
  vehicleAirConditioning  Boolean?       @map("vehicle_air_conditioning")
  vehicleAirbag           Boolean?       @map("vehicle_airbag")
  vehicleSteering         String?        @map("vehicle_steering")
  vehiclePowerWindows     Boolean?       @map("vehicle_power_windows")
  vehicleAlarm            Boolean?       @map("vehicle_alarm")
  vehicleMultimedia       Boolean?       @map("vehicle_multimedia")
  vehicleAdditionalInfo   String?        @map("vehicle_additional_info")
  batches                 ProductBatch[]
  company                 Company        @relation(fields: [companyId], references: [id])
  foodOrderItems          FoodOrderItem[]
  supplier                Supplier?      @relation(fields: [supplierId], references: [id])
  sales                   SaleItem[]

  @@unique([companyId, barcode])
  @@index([companyId], map: "idx_products_company_id")
  @@index([stock, costPrice, salePrice], map: "idx_products_stock_prices")
  @@index([companyId, vehiclePlate], map: "idx_products_company_vehicle_plate")
  @@index([companyId, vehicleChassis], map: "idx_products_company_vehicle_chassis")
  @@map("products")
}

model ProductBatch {
  id        Int       @id @default(autoincrement())
  productId String    @map("product_id")
  quantity  Int
  costPrice Decimal   @map("cost_price") @db.Decimal(10, 2)
  salePrice Decimal   @map("sale_price") @db.Decimal(10, 2)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_product")

  @@index([productId], map: "idx_product_batches_pid")
  @@map("product_batches")
}

model ServiceOrder {
  deviceModel    String    @map("device_model")
  companyId      String    @map("company_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  checklist      Json?
  clientCpf      String?   @map("client_cpf")
  clientName     String    @map("client_name")
  clientPhone    String    @map("client_phone")
  costPrice      Float     @default(0) @map("cost_price")
  customerId     String?   @map("customer_id")
  deviceBrand    String    @map("device_brand")
  deviceColor    String?   @map("device_color")
  devicePassword String?   @map("device_password")
  observations   String?
  paymentMethod  String?   @map("payment_method")
  problem        String
  serialNumber   String?   @map("serial_number")
  servicePrice   Float     @default(0) @map("service_price")
  totalPrice     Float     @default(0) @map("total_price")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  id             Int       @id @default(autoincrement())
  status         OSStatus  @default(ABERTO)
  company        Company   @relation(fields: [companyId], references: [id])
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId], map: "idx_os_company_id")
  @@map("os")
}

model Supplier {
  id         String    @id @default(uuid())
  companyId  String    @default("multicell-oficial") @map("company_id")
  name       String
  contact    String?
  whatsapp   String?
  catalogUrl String?   @map("catalog_url")
  products   Product[]

  @@index([companyId], map: "idx_suppliers_company_id")
  @@map("suppliers")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Sale {
  id             Int        @id @default(autoincrement())
  companyId      String     @map("company_id")
  foodOrderId    String?    @map("food_order_id")
  total          Float
  discount       Float?     @default(0)
  feeAmount      Float?     @default(0) @map("fee_amount")
  netAmount      Float?     @map("net_amount")
  paymentMethod  String     @map("payment_method")
  cardType       String?    @map("card_type")
  financingBank  String?    @map("financing_bank")
  tableNumber    String?    @map("table_number")
  serviceOrderId Int?       @map("service_order_id")
  status         SaleStatus @default(COMPLETED)
  returnReason   String?    @map("return_reason")
  customerId     String?    @map("customer_id")
  customerDocument String?  @map("customer_document")
  sellerId       String?    @map("seller_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  company        Company    @relation(fields: [companyId], references: [id])
  foodOrder      FoodOrder? @relation(fields: [foodOrderId], references: [id], onDelete: SetNull)
  items          SaleItem[]
  customer       Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  nfeLogs        NfeLog[]
  seller         User?      @relation("SellerSales", fields: [sellerId], references: [id], onDelete: SetNull)

  @@index([companyId], map: "idx_sales_company_id")
  @@index([companyId, createdAt], map: "idx_sales_company_created_at")
  @@index([foodOrderId], map: "idx_sales_food_order_id")
  @@map("sales")
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  saleId      Int      @map("sale_id")
  productId   String?  @map("product_id")
  description String?
  quantity    Int
  unitPrice   Float    @map("unit_price")
  product     Product? @relation(fields: [productId], references: [id])
  sale        Sale     @relation(fields: [saleId], references: [id])

  @@map("sale_items")
}

model Table {
  id             String      @id @default(cuid())
  companyId      String      @map("company_id")
  number         String
  status         TableStatus @default(DISPONIVEL)
  currentOrderId String?     @unique @map("current_order_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  company        Company     @relation(fields: [companyId], references: [id])
  currentOrder   FoodOrder?  @relation("CurrentTableOrder", fields: [currentOrderId], references: [id], onDelete: SetNull)
  orders         FoodOrder[] @relation("TableOrders")

  @@unique([companyId, number])
  @@index([companyId, status], map: "idx_tables_company_status")
  @@map("tables")
}

model FoodOrder {
  id                      String               @id @default(cuid())
  companyId               String               @map("company_id")
  customerId              String?              @map("customer_id")
  tableId                 String?              @map("table_id")
  status                  FoodOrderStatus      @default(ABERTA)
  notes                   String?
  total                   Float                @default(0)
  paidAmount              Float                @default(0) @map("paid_amount")
  pendingTransferredAmount Float               @default(0) @map("pending_transferred_amount")
  balanceDue              Float                @default(0) @map("balance_due")
  openedAt                DateTime             @default(now()) @map("opened_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")
  closedAt                DateTime?            @map("closed_at")
  company                 Company              @relation(fields: [companyId], references: [id])
  customer                Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  table                   Table?               @relation("TableOrders", fields: [tableId], references: [id], onDelete: SetNull)
  currentForTable         Table?               @relation("CurrentTableOrder")
  items                   FoodOrderItem[]
  payments                FoodOrderPayment[]
  pendingEntries          CustomerPendingEntry[]
  sales                   Sale[]

  @@index([companyId, status], map: "idx_food_orders_company_status")
  @@index([customerId], map: "idx_food_orders_customer_id")
  @@map("food_orders")
}

model FoodOrderItem {
  id              String    @id @default(cuid())
  orderId         String    @map("order_id")
  productId       String?   @map("product_id")
  description     String
  quantity        Int
  settledQuantity Int       @default(0) @map("settled_quantity")
  unitPrice       Float     @map("unit_price")
  createdAt       DateTime  @default(now()) @map("created_at")
  order           FoodOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId], map: "idx_food_order_items_order_id")
  @@map("food_order_items")
}

model FoodOrderPayment {
  id              String                @id @default(cuid())
  orderId         String                @map("order_id")
  customerId      String?               @map("customer_id")
  amount          Float
  paymentMethod   String                @map("payment_method")
  notes           String?
  dueDate         DateTime?             @map("due_date") @db.Date
  receiptDocument String?               @map("receipt_document")
  createdAt       DateTime              @default(now()) @map("created_at")
  order           FoodOrder             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer        Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  pendingEntry    CustomerPendingEntry?

  @@index([orderId, createdAt], map: "idx_food_order_payments_order_created_at")
  @@map("food_order_payments")
}

model CustomerPendingEntry {
  id           String               @id @default(cuid())
  companyId    String               @map("company_id")
  customerId   String               @map("customer_id")
  orderId      String?              @map("order_id")
  paymentId    String?              @unique @map("payment_id")
  amount       Float
  dueDate      DateTime?            @map("due_date") @db.Date
  status       PendingAccountStatus @default(ABERTO)
  description  String?
  itemsSnapshot Json?               @map("items_snapshot")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  settledAt    DateTime?            @map("settled_at")
  company      Company              @relation(fields: [companyId], references: [id])
  customer     Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order        FoodOrder?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  payment      FoodOrderPayment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([companyId, status, dueDate], map: "idx_pending_entries_company_status_due_date")
  @@index([customerId, createdAt], map: "idx_pending_entries_customer_created_at")
  @@map("customer_pending_entries")
}

model CompanyConfig {
  id         String   @id @default(cuid())
  name       String   @default("Minha Empresa")
  address    String?
  phone      String?
  companyId  String   @unique @default("multicell-oficial") @map("company_id")
  creditRate Float    @default(3.99) @map("credit_rate")
  debitRate  Float    @default(1.99) @map("debit_rate")
  document   String?
  logoUrl    String?  @default("/wtm-float.png") @map("logo_url")
  updatedAt  DateTime @updatedAt @map("updated_at")
  taxPix     Float    @default(0) @map("tax_pix")
  taxCash    Float    @default(0) @map("tax_cash")
  company    Company  @relation(fields: [companyId], references: [id])

  @@index([companyId], map: "idx_company_config_company_id")
  @@map("company_config")
}

model Company {
  id                 String              @id
  name               String              @default("Minha Empresa")
  segment            Segment?
  cnpj               String?
  address            String?
  phone              String?
  email              String?
  logoUrl            String?             @default("/wtm-float.png") @map("logo_url")
  certificateA1      String?             @map("certificate_a1")
  companyData        Json?               @map("company_data")
  settings           Json?
  nfeBalance         Decimal             @default(0) @map("nfe_balance") @db.Decimal(10, 2)
  autoTopUp          Boolean             @default(false) @map("auto_top_up")
  trialEndsAt        DateTime            @default(dbgenerated("(now() + interval '7 days')")) @map("trial_ends_at")
  subscriptionStatus String              @default("trialing") @map("subscription_status")
  mpSubscriptionId   String?             @map("mp_subscription_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  config             CompanyConfig?
  foodOrders         FoodOrder[]
  pendingEntries     CustomerPendingEntry[]
  expenses           Expense[]
  nfeLogs            NfeLog[]
  nfeWalletRecharges NfeWalletRecharge[]
  products           Product[]
  salaryAdvances     SalaryAdvance[]
  sales              Sale[]
  serviceOrders      ServiceOrder[]
  tables             Table[]
  users              User[]

  @@map("companies")
}

model User {
  id                String    @id @default(uuid())
  name              String?
  fullName          String?   @map("full_name")
  email             String    @unique
  cpf               String?   @unique
  birthDate         DateTime? @map("birth_date") @db.Date
  commissionRate    Decimal   @default(0.00) @map("commission_rate") @db.Decimal(5, 2)
  role              UserRole  @default(ATTENDANT)
  password          String
  resetToken        String?   @map("reset_token")
  resetTokenExpires DateTime? @map("reset_token_expires")
  companyId         String    @map("company_id")
  company           Company   @relation(fields: [companyId], references: [id])
  sales             Sale[]    @relation("SellerSales")
  salaryAdvances    SalaryAdvance[] @relation("EmployeeSalaryAdvances")

  @@index([companyId], map: "idx_users_company_id")
  @@map("users")
}

model NfeLog {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  saleId         Int?     @map("sale_id")
  documentNumber String   @map("document_number")
  amount         Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  company        Company  @relation(fields: [companyId], references: [id])
  sale           Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt], map: "idx_nfe_logs_company_created_at")
  @@index([saleId], map: "idx_nfe_logs_sale_id")
  @@map("nfe_logs")
}

model NfeWalletRecharge {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  mpPaymentId String   @unique @map("mp_payment_id")
  amount      Decimal  @db.Decimal(10, 2)
  status      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId, createdAt], map: "idx_nfe_wallet_recharges_company_created_at")
  @@map("nfe_wallet_recharges")
}

model Expense {
  id            String                @id @default(cuid())
  description   String
  category      ExpenseCategory
  amount        Decimal               @db.Decimal(10, 2)
  dueDate       DateTime              @map("due_date")
  isRecurring   Boolean               @default(false) @map("is_recurring")
  nextDueDate   DateTime?             @map("next_due_date")
  paidAt        DateTime?             @map("paid_at")
  status        ExpenseStatus         @default(PENDING)
  type          ExpenseType           @default(SHOP)
  paymentMethod ExpensePaymentMethod? @map("payment_method")
  companyId     String                @default("multicell-oficial") @map("company_id")
  createdAt     DateTime              @default(now()) @map("created_at")
  company       Company               @relation(fields: [companyId], references: [id])
  salaryAdvance SalaryAdvance?
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@index([companyId], map: "idx_expenses_company_id")
  @@index([companyId, status, dueDate])
  @@index([companyId, paidAt])
  @@index([companyId, isRecurring, dueDate])
  @@map("expenses")
}

model SalaryAdvance {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  employeeId      String?   @map("employee_id")
  expenseId       String    @unique @map("expense_id")
  employeeName    String    @map("employee_name")
  employeeCpf     String    @map("employee_cpf")
  grossSalary     Decimal   @map("gross_salary") @db.Decimal(10, 2)
  advanceAmount   Decimal   @map("advance_amount") @db.Decimal(10, 2)
  remainingSalary Decimal   @map("remaining_salary") @db.Decimal(10, 2)
  referenceMonth  DateTime  @map("reference_month") @db.Date
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  company         Company   @relation(fields: [companyId], references: [id])
  employee        User?     @relation("EmployeeSalaryAdvances", fields: [employeeId], references: [id], onDelete: SetNull)
  expense         Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([companyId, referenceMonth], map: "idx_salary_advances_company_reference_month")
  @@index([companyId, employeeCpf, referenceMonth], map: "idx_salary_advances_employee_cpf_reference_month")
  @@index([employeeId], map: "idx_salary_advances_employee_id")
  @@map("salary_advances")
}

model AuditLog {
  id          String      @id @default(cuid())
  companyId   String      @default("multicell-oficial") @map("company_id")
  userName    String      @map("user_name")
  action      AuditAction
  tableName   String      @map("table_name")
  description String
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([companyId], map: "idx_audit_logs_company_id")
  @@index([companyId, createdAt])
  @@map("audit_logs")
}

model DailyClosing {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()"))
  companyId           String    @default("multicell-oficial") @map("company_id")
  date                DateTime  @unique @db.Date
  totalCash           Float     @default(0) @map("total_cash")
  totalPix            Float     @default(0) @map("total_pix")
  totalDebit          Float     @default(0) @map("total_debit")
  totalCredit         Float     @default(0) @map("total_credit")
  totalNet            Float     @default(0) @map("total_net")
  status              String    @default("OPEN")
  closedAt            DateTime? @map("closed_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  total_bruto         Float?    @default(0)
  total_taxas         Float?    @default(0)
  total_liquido       Float?    @default(0)
  vendas_qtd          Int?      @default(0)
  total_lucro_diario  Float?    @default(0)
  total_lucro_semanal Float?    @default(0)
  total_lucro_mensal  Float?    @default(0)
  valor_total_estoque Float?    @default(0)

  @@unique([date, companyId])
  @@index([companyId], map: "idx_daily_closing_company_id")
  @@map("daily_closing")
}

enum Segment {
  TECH
  RETAIL
  AUTO
  BEAUTY
  FOOD
}

enum VehicleStatus {
  DISPONIVEL
  MANUTENCAO
  VENDIDO
}

enum TableStatus {
  DISPONIVEL
  OCUPADO
}

enum FoodOrderStatus {
  ABERTA
  PARCIAL
  FECHADA
}

enum PendingAccountStatus {
  ABERTO
  PAGO
  VENCIDO
}

enum OSStatus {
  ABERTO
  EM_REPARO
  AGUARDANDO_PECA
  PRONTO
  FINALIZADO
  CANCELADO
  EM_ANDAMENTO
}

enum SaleStatus {
  COMPLETED
  REFUNDED
}

enum ExpenseCategory {
  ALUGUEL
  AGUA
  ENERGIA
  INTERNET
  ADIANTAMENTO_SALARIAL
  OUTROS
}

enum ExpenseStatus {
  PENDING
  PAID
}

enum ExpenseType {
  SHOP
  PERSONAL
}

enum ExpensePaymentMethod {
  PIX
  DINHEIRO
  CARTAO
}

enum UserRole {
  ADMIN
  ATTENDANT
}

enum AuditAction {
  INSERT
  UPDATE
  DELETE
}
